---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const titleVi = "MedNova Instruments | Giải pháp thiết bị y tế hiện đại";
const titleEn = "MedNova Instruments | Modern Medical Equipment Solutions";
---

<BaseLayout
  title={titleVi}
  description="Trang giới thiệu MedNova Instruments: định hướng phát triển thiết bị y tế hiện đại, an toàn và ứng dụng thực tiễn."
>
  <main class="page-shell" data-title-vi={titleVi} data-title-en={titleEn}>
    <div class="surface">
      <SiteHeader activePath="home" showCart={false} />

      <section class="home-intro">
        <article class="home-hero">
          <span
            class="eyebrow"
            data-en="Future-ready Healthcare Technology"
            data-vi="Công nghệ y tế hướng đến tương lai"
          >
            Công nghệ y tế hướng đến tương lai
          </span>

          <h1
            data-en="Medical equipment is evolving from standalone devices to connected clinical ecosystems."
            data-vi="Thiết bị y tế đang chuyển dịch từ máy đơn lẻ sang hệ sinh thái lâm sàng kết nối."
          >
            Thiết bị y tế đang chuyển dịch từ máy đơn lẻ sang hệ sinh thái lâm sàng kết nối.
          </h1>

          <p
            class="home-copy"
            data-en="MedNova focuses on reliability, safety, and interoperability so clinics can scale care quality with confidence."
            data-vi="MedNova tập trung vào độ tin cậy, an toàn và khả năng liên thông để phòng khám mở rộng chất lượng điều trị một cách vững chắc."
          >
            MedNova tập trung vào độ tin cậy, an toàn và khả năng liên thông để phòng khám mở rộng chất lượng điều trị một cách vững chắc.
          </p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="/products" data-en="Explore Products" data-vi="Khám phá sản phẩm">
              Khám phá sản phẩm
            </a>
            <a class="btn btn-light" href="/about" data-en="About Company" data-vi="Giới thiệu công ty">
              Giới thiệu công ty
            </a>
          </div>
        </article>

        <aside class="home-highlight">
          <div class="pulse-ring" aria-hidden="true"></div>
          <div class="home-stat">
            <p class="stat-value">4.0</p>
            <p
              class="stat-label"
              data-en="Generation of smart medical ecosystems"
              data-vi="Thế hệ hệ sinh thái y tế thông minh"
            >
              Thế hệ hệ sinh thái y tế thông minh
            </p>
          </div>
          <div class="home-stat">
            <p class="stat-value">IoMT</p>
            <p
              class="stat-label"
              data-en="Connected devices + centralized monitoring"
              data-vi="Thiết bị kết nối + giám sát tập trung"
            >
              Thiết bị kết nối + giám sát tập trung
            </p>
          </div>
        </aside>
      </section>

      <section class="evolution">
        <div class="section-head">
          <div>
            <h2
              data-en="Evolution of Medical Equipment"
              data-vi="Sự phát triển của thiết bị y tế"
            >
              Sự phát triển của thiết bị y tế
            </h2>
            <p
              class="section-note"
              data-en="From analog machines to AI-assisted decision support."
              data-vi="Từ máy analog đến nền tảng hỗ trợ quyết định bằng AI."
            >
              Từ máy analog đến nền tảng hỗ trợ quyết định bằng AI.
            </p>
          </div>
        </div>

        <div class="timeline-grid">
          <article class="timeline-card">
            <p class="timeline-year">1970s-1990s</p>
            <h3 data-en="Analog to Digital Transition" data-vi="Chuyển đổi từ analog sang số hóa">
              Chuyển đổi từ analog sang số hóa
            </h3>
            <p
              data-en="Core devices such as ECG and patient monitors moved toward stable digital signal processing."
              data-vi="Các thiết bị nền tảng như ECG và monitor bắt đầu chuyển sang xử lý tín hiệu số ổn định hơn."
            >
              Các thiết bị nền tảng như ECG và monitor bắt đầu chuyển sang xử lý tín hiệu số ổn định hơn.
            </p>
          </article>

          <article class="timeline-card">
            <p class="timeline-year">2000s</p>
            <h3 data-en="Clinical Workflow Integration" data-vi="Tích hợp vào quy trình lâm sàng">
              Tích hợp vào quy trình lâm sàng
            </h3>
            <p
              data-en="Hospital systems introduced networked devices, central dashboards, and electronic records compatibility."
              data-vi="Hệ thống bệnh viện đưa vào thiết bị kết nối mạng, bảng điều khiển tập trung và tương thích hồ sơ điện tử."
            >
              Hệ thống bệnh viện đưa vào thiết bị kết nối mạng, bảng điều khiển tập trung và tương thích hồ sơ điện tử.
            </p>
          </article>

          <article class="timeline-card">
            <p class="timeline-year">2015-Now</p>
            <h3 data-en="Smart, Predictive, and Connected Care" data-vi="Chăm sóc thông minh, dự báo và liên thông">
              Chăm sóc thông minh, dự báo và liên thông
            </h3>
            <p
              data-en="AI-assisted insights, cloud synchronization, and remote diagnostics enable faster and safer interventions."
              data-vi="Phân tích hỗ trợ AI, đồng bộ đám mây và chẩn đoán từ xa giúp can thiệp nhanh và an toàn hơn."
            >
              Phân tích hỗ trợ AI, đồng bộ đám mây và chẩn đoán từ xa giúp can thiệp nhanh và an toàn hơn.
            </p>
          </article>
        </div>
      </section>

      <section class="vision-strip">
        <p
          data-en="Our vision: make advanced medical technology practical, maintainable, and accessible for every clinic scale."
          data-vi="Tầm nhìn của chúng tôi: biến công nghệ y tế tiên tiến thành giải pháp thực tiễn, dễ bảo trì và phù hợp mọi quy mô phòng khám."
        >
          Tầm nhìn của chúng tôi: biến công nghệ y tế tiên tiến thành giải pháp thực tiễn, dễ bảo trì và phù hợp mọi quy mô phòng khám.
        </p>
      </section>

      <footer class="site-footer">
        <p
          data-en="MedNova Instruments · Introductory homepage"
          data-vi="MedNova Instruments · Trang giới thiệu tổng quan"
        >
          MedNova Instruments · Trang giới thiệu tổng quan
        </p>
        <p>sales@mednova.demo · +84 28 9999 5588</p>
      </footer>
    </div>
  </main>
</BaseLayout>

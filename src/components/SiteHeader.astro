---
type ActivePath = "home" | "products" | "about" | "admin";

interface Props {
  activePath?: ActivePath;
  showCart?: boolean;
  showAdminLink?: boolean;
}

const { activePath = "home", showCart = true, showAdminLink = true } = Astro.props;
---

<header class="site-header">
  <div class="brand">
    <a class="brand-title-link" href="/">
      <p class="brand-title">MedNova Instruments</p>
    </a>
    <p
      class="brand-subtitle"
      data-en="Hospital-grade devices for modern clinics"
      data-vi="Thiết bị chuẩn bệnh viện cho phòng khám hiện đại"
    >
      Thiết bị chuẩn bệnh viện cho phòng khám hiện đại
    </p>
  </div>

  <nav class="main-nav" aria-label="Primary navigation">
    <a
      class:list={["nav-link", activePath === "products" && "active"]}
      href="/products"
      data-en="Products"
      data-vi="Sản phẩm"
    >
      Sản phẩm
    </a>
    <a
      class:list={["nav-link", activePath === "about" && "active"]}
      href="/about"
      data-en="Company"
      data-vi="Giới thiệu công ty"
    >
      Giới thiệu công ty
    </a>
    {
      showAdminLink && (
        <a
          class:list={["nav-link", "nav-admin", activePath === "admin" && "active"]}
          href="/admin"
          data-en="Admin"
          data-vi="Quản trị"
        >
          Quản trị
        </a>
      )
    }
  </nav>

  <div class="header-tools">
    {
      showCart && (
        <button class="cart-trigger" type="button" data-cart-open>
          <span data-en="Cart" data-vi="Giỏ hàng">Giỏ hàng</span>
          <span class="cart-count" data-cart-count>0</span>
        </button>
      )
    }

    <div class="lang-switch" role="group" aria-label="Language switch">
      <button type="button" data-lang-switch="vi" aria-pressed="true">VI</button>
      <button type="button" data-lang-switch="en" aria-pressed="false">EN</button>
    </div>
  </div>
</header>
